App(
    appid="thermal_camera",
    name="Thermal Camera",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="thermal_camera_app",
    requires=["gui"],
    stack_size=6 * 1024,
    sources=[
        "thermal_camera.c",
        "mlx90640/*.c",
        "ui/*.c",
        "ui/views/*.c",
    ],
    fap_icon="icon.png",
    fap_category="GPIO",
    fap_version=(1, 0),
)
